{
  "manifest_version": 3,
  "name": "Spotlight Search - Quick Tab Finder",
  "version": "1.1.0",
  "description": "Spotlight-style search for Chrome. Press Ctrl+Q or hold right-click and drag down to instantly find tabs and search the web.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://www.google.com/*"
  ],
  "commands": {
    "toggle-spotlight": {
      "suggested_key": {
        "default": "Ctrl+Q"
      },
      "description": "Toggle Spotlight Search - Quick Tab Finder"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["spotlight.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Spotlight Search - Quick Tab Finder (Ctrl+Q)"
  }
}
